# Copy this file to `.env` and fill in your values.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=voting_system
PORT=5000

# Admin login fallback — used when the `admins` MySQL table is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ── Automatic Excel backup + Google Drive sync (all optional) ───────────────
# With none of these set, every vote is still backed up to a local Excel file
# (express-backend/data/votes_backup.xlsx); only the Google Drive upload is
# skipped.
#
# To enable Drive sync:
#   1. Create a Google Cloud Service Account, enable the Drive API, download
#      its JSON key to express-backend/credentials/service-account.json
#   2. Share the target Drive folder with the service account's client_email
#   3. Point GOOGLE_SERVICE_ACCOUNT_KEY_FILE at the JSON file below
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials/voting.json
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FILE_ID=
BACKUP_DIR=./data
