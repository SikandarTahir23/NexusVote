# NexusVote — environment configuration template.
# Copy this file to `.env.local` and fill in real values.
# See the comments in `.env.local` for full setup instructions.

# EmailJS — required to send real OTP emails. The "demo_" placeholders make
# the app run in demo mode (OTP is shown on screen + console instead of
# emailed). Replace these with real EmailJS Service / Template / Public-Key
# values from https://www.emailjs.com/ to send real emails.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=demo_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=demo_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=demo_public_key

# Vote-confirmation email template (the "Vote Successfully Casted" receipt).
# Reuses the same EmailJS Service + Public Key above. Create a second EmailJS
# template whose body references {{voter_name}}, {{reference_number}},
# {{vote_timestamp}} (or just {{message}} for the ready-made full body) and
# put its Template ID here. If left as the demo placeholder the confirmation
# email runs in demo mode (logged to the browser console, not sent). When
# unset it falls back to NEXT_PUBLIC_EMAILJS_TEMPLATE_ID above.
NEXT_PUBLIC_EMAILJS_VOTE_TEMPLATE_ID=demo_vote_template_id

# Optional — only used if/when the Express backend is reconnected.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Admin demo credentials — used by /api/admin/login (server-side only, no
# NEXT_PUBLIC_ prefix so they never reach the browser bundle).
# Replace these before any real deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
